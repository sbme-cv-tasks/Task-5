  <property name="styleSheet">
   <string notr="true">
QMainWindow { background-color: #0f1419; }
QWidget#centralwidget { background-color: #1a202c; }

/* Left Panel Styles */
QLabel#image_label {
    background-color: #2d3748;
    color: #e2e8f0;
    border: 2px dashed #667eea;
    border-radius: 12px;
    font-size: 18px;
}
QLabel#image_label:hover {
    border: 2px dashed #764ba2;
    background-color: #354054;
}

/* Right Panel Styles */
QGroupBox#results_group {
    color: #e2e8f0;
    font-size: 16px;
    font-weight: bold;
    border: 1px solid #4a5568;
    border-radius: 8px;
    margin-top: 15px;
}
QGroupBox#results_group::title {
    subcontrol-origin: margin;
    left: 15px;
    padding: 0 5px;
}
/* Fixed: Targeting elements by their exact ID instead of a class */
QLabel#subject_info, QLabel#distance_info {
    color: #cbd5e0;
    font-size: 15px;
    font-weight: normal;
}
QLabel#match_label {
    background-color: #0f1419;
    border: 1px solid #4a5568;
    border-radius: 8px;
}

/* Buttons */
QPushButton {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #667eea, stop:1 #764ba2);
    color: white;
    font-size: 16px;
    font-weight: bold;
    border-radius: 8px;
    padding: 12px;
    min-height: 45px;
}
QPushButton:hover {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #764ba2, stop:1 #667eea);
}
QPushButton#roc_btn {
    background-color: #2b6cb0;
}
QPushButton#roc_btn:hover {
    background-color: #2c5282;
}
   </string>
